# ---------------------------------------------------------------------------
# GPU Microservice — Environment Variables
# ---------------------------------------------------------------------------

# Comma-separated list of IPs allowed to access the service.
# Leave empty to allow all traffic (convenient for local dev).
# In production, set this to the IP(s) of your Node.js backend.
# Example: ALLOWED_IPS=10.0.0.5,192.168.1.100
ALLOWED_IPS=

# HuggingFace model name for embeddings.
# Default: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
